{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "useRootPaddingAwareAlignments": true,
    "layout": {
      "contentSize": "840px",
      "wideSize": "1280px"
    },
    "color": {
      "palette": [
        {
          "slug": "primary",
          "name": "Primary",
          "color": "#0d6efd"
        },
        {
          "slug": "dark",
          "name": "Dark",
          "color": "#111827"
        },
        {
          "slug": "text",
          "name": "Text",
          "color": "#14213d"
        },
        {
          "slug": "muted",
          "name": "Muted",
          "color": "#5c677d"
        },
        {
          "slug": "surface",
          "name": "Surface",
          "color": "#f7f8fb"
        },
        {
          "slug": "white",
          "name": "White",
          "color": "#ffffff"
        }
      ]
    },
    "spacing": {
      "units": [
        "px",
        "rem",
        "vw",
        "vh",
        "%"
      ],
      "spacingSizes": [
        {
          "slug": "20",
          "name": "XS",
          "size": "0.75rem"
        },
        {
          "slug": "30",
          "name": "S",
          "size": "1rem"
        },
        {
          "slug": "40",
          "name": "M",
          "size": "1.5rem"
        },
        {
          "slug": "50",
          "name": "L",
          "size": "2.25rem"
        },
        {
          "slug": "60",
          "name": "XL",
          "size": "3rem"
        },
        {
          "slug": "70",
          "name": "2XL",
          "size": "4rem"
        }
      ]
    },
    "typography": {
      "fluid": true,
      "fontFamilies": [
        {
          "slug": "system-sans",
          "name": "System Sans",
          "fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Inter, sans-serif"
        }
      ],
      "fontSizes": [
        {
          "slug": "small",
          "size": "0.875rem",
          "name": "Small"
        },
        {
          "slug": "medium",
          "size": "1rem",
          "name": "Medium"
        },
        {
          "slug": "large",
          "size": "1.25rem",
          "name": "Large"
        },
        {
          "slug": "x-large",
          "size": "2rem",
          "name": "XL"
        },
        {
          "slug": "xx-large",
          "size": "3rem",
          "name": "2XL"
        }
      ]
    },
    "blocks": {
      "core/button": {
        "border": {
          "radius": true
        }
      },
      "core/navigation": {
        "typography": {
          "fontSize": true
        }
      },
      "core/post-featured-image": {
        "border": {
          "radius": true
        }
      }
    },
    "custom": {
      "spacing": {
        "headerOffset": "90px"
      }
    }
  },
  "styles": {
    "css": ":root{--wp--style--root--padding-inline:1rem;}",
    "spacing": {
      "blockGap": "1.25rem"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--system-sans)",
      "lineHeight": "1.6"
    },
    "elements": {
      "button": {
        "color": {
          "background": "var(--wp--preset--color--primary)",
          "text": "#ffffff"
        },
        "border": {
          "radius": "999px"
        }
      },
      "heading": {
        "typography": {
          "lineHeight": "1.15"
        }
      },
      "link": {
        "color": {
          "text": "var(--wp--preset--color--primary)"
        }
      }
    },
    "blocks": {
      "core/site-title": {
        "typography": {
          "fontWeight": "700"
        }
      },
      "core/navigation": {
        "typography": {
          "fontWeight": "600"
        }
      },
      "core/post-featured-image": {
        "border": {
          "radius": "18px"
        }
      }
    }
  },
  "templateParts": [
    {
      "area": "header",
      "name": "header",
      "title": "Header"
    },
    {
      "area": "footer",
      "name": "footer",
      "title": "Footer"
    }
  ]
}